using UnityEngine;

public class TouchInteraction3D : MonoBehaviour
{
    void Update()
    {
        if (Input.touchCount > 0 && Input.GetTouch(0).phase == TouchPhase.Began)
        {
            Ray ray = Camera.main.ScreenPointToRay(Input.GetTouch(0).position);
            RaycastHit hit;

            if (Physics.Raycast(ray, out hit))
            {
                KakaoObject objekKakao = hit.collider.GetComponent<KakaoObject>();
                if (objekKakao != null)
                {
                    objekKakao.EksekusiAksi();
                }
            }
        }
    }
}
